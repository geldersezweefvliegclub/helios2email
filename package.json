{
  "name": "helios2email",
  "version": "1.0.0",
  "description": "NestJS background worker that fetches daginfo from Helios and emails subscribers daily at 22:00.",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.1.2",
    "google-auth-library": "^9.15.1",
    "googleapis": "^140.0.0",
    "joi": "^17.12.3",
    "js-base64": "^3.7.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
